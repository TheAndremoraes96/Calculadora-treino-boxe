rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "alucasdemoraes96@gmail.com";
    }

    // App público: cadastro de atletas
    match /cadastros/{id} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // Premium: usuário pode ler para validar código; somente admin cria/altera/remove
    match /premiumKeys/{codigo} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Assinantes: somente admin gerencia
    match /assinantes/{codigo} {
      allow read, write: if isAdmin();
    }

    // Avaliações: app pode criar, admin gerencia
    match /avaliacoes/{id} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // Histórico
    match /historicoAvaliacoes/{id} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // Feed
    match /feed/{id} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // Eventos
    match /eventos/{id} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // Bloqueia qualquer coleção fora do app
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
