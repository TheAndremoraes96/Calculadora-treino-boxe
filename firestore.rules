rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "alucasdemoraes96@gmail.com";
    }

    function publicPremiumActivationOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(["usado", "status", "activationDeviceId", "ultimoUso"])
        && resource.data.ativo == true
        && (
          !("dataExpiracao" in resource.data)
          || request.time < timestamp(resource.data.dataExpiracao)
        );
    }

    // Cadastro público de atletas.
    // Público pode criar e ler. Só o admin altera/exclui.
    match /cadastros/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Chaves Premium.
    // Cliente pode buscar um código específico e ativar somente campos permitidos.
    // Só admin cria, renova, desativa ou exclui.
    match /premiumKeys/{codigo} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || publicPremiumActivationOnly();
    }

    // Assinantes: somente admin.
    match /assinantes/{codigo} {
      allow read, write: if isAdmin();
    }

    // Avaliações.
    match /avaliacoes/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Histórico de avaliações.
    match /historicoAvaliacoes/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Feed.
    match /feed/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Eventos.
    match /eventos/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Bloqueia qualquer coleção fora do app.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
